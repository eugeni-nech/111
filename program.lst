0001   0000                     .org 000h       ; Начальный адрес (для CP/M или простого вывода)
0002   0000             
0003   0000 0E 02       start:  mvi c, 02h      ; Функция вывода символа (может зависеть от системы)
0004   0002 1E 40               mvi e, 40h      ; Символ 'A'
0005   0004 CD 05 00            Call  5         ;  Вызов системной функции (для теста синтаксиса)
0006   0007             
0007   0007 C3 00 00            jmp start       ; Бесконечный цикл
0008   000A             
0009   000A             
0010   000A                     .end start
0011   000A                tasm: Number of errors = 0
